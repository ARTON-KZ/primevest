# ─── Rack Invest — environment variables ──────────────────────────────────────
# Copy this file to ".env" for local dev. In production set these in your host's
# dashboard (Railway/Render/etc). Never commit your real .env (it is gitignored).

# Port — most hosts inject this automatically. Local default is 3001
# (port 3000 is taken by another app on this machine).
PORT=3001

# Secret used to sign JWT auth tokens. Use a long random string in production.
JWT_SECRET=change_this_to_a_long_random_string

# Database file. Local dev: leave blank to use ./rack.db in the project folder.
# Production: point at a mounted volume so data survives deploys, e.g. /data/rack.db
DB_PATH=

# Public base URL of the site (used in emails for the deposit link).
BASE_URL=http://localhost:3001

# Allowed CORS origin(s). "*" or a comma-separated list of frontend origins.
ALLOWED_ORIGIN=*

# ─── Seed admin account (created on first run if no admin exists) ──────────────
ADMIN_EMAIL=admin@primevest.com
ADMIN_PASSWORD=Admin@1234

# ─── Email (nodemailer SMTP) ──────────────────────────────────────────────────
# Welcome emails are sent on signup. If these are left blank the email is logged
# to the console instead, so local dev still works without a mail server.
# Works with Gmail (use an App Password), Zoho, Mailgun SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# "From" address shown to recipients.
MAIL_FROM="PrimeVest <no-reply@primevest.com>"
